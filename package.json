{
  "name": "greengold-billing",
  "version": "1.0.0",
  "description": "GreenGold Silage and Services Billing Software",
  "main": "main.js",
  "author": "GreenGold",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.greengold.billing",
    "productName": "GreenGold Billing",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
